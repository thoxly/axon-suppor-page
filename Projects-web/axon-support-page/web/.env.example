# Direct Postgres connection string (Database > Settings > Connection string > Pooling)
SUPABASE_URL=postgres://postgres.xxxx:password@aws-0-xx-xxx.pooler.supabase.com:5432/postgres

# Supabase Auth SDK (@supabase/ssr) — Project URL + Publishable Key (safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Secret Key (Settings → API Keys → Secret keys; backend only, used for auth.admin.*)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx

ELMA_API_BASE_URL=https://elma-dev.copycon.ru/pub/v1
ELMA_API_KEY=your-elma-api-key

ELMA_OTP_WEBHOOK_URL=https://elma-dev.copycon.ru/api/extensions/ddd669fb-a3e8-4f77-97e9-fc40c044a9fe/script/get_email

NEXT_PUBLIC_SITE_URL=http://localhost:3000

